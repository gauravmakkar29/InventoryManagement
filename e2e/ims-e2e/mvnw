# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
#
# Optional ENV vars
#   JAVA_HOME - location of a JDK home dir
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
# ----------------------------------------------------------------------------

set -euf
[ "${MVNW_VERBOSE-}" != true ] || set -x

# OS specific support.
native_path() { printf %s\\n "$1"; }
case "$(uname)" in
CYGWIN* | MINGW*)
  [ -z "${JAVA_HOME-}" ] || JAVA_HOME="$(cygpath --unix "$JAVA_HOME")"
  native_path() { cygpath --path --windows "$1"; }
  ;;
esac

# set JAVA_CMD
if [ -n "${JAVA_HOME-}" ]; then
  if [ -x "$JAVA_HOME/jre/sh/java" ]; then
    JAVA_CMD="$JAVA_HOME/jre/sh/java"
  elif [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
  else
    echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME" >&2
    echo "Please set the JAVA_HOME variable in your environment to match the location of your Java installation." >&2
    exit 1
  fi
else
  JAVA_CMD="$(
    'set' +e
    'unset' -f command 2>/dev/null
    'command' -v java
  )" || :
  if [ ! -x "${JAVA_CMD-}" ]; then
    echo "ERROR: JAVA_HOME is not set and 'java' command not found." >&2
    echo "Please set the JAVA_HOME variable in your environment to match the location of your Java installation." >&2
    exit 1
  fi
fi

# hash string like  groovy  ANT_OPTS
hash_string() {
  str="${1:-}" h=0
  while [ -n "$str" ]; do
    char="${str%"${str#?}"}"
    h=$(((h * 31 + $(LC_CTYPE=C printf %d "'$char")) % 4294967296))
    str="${str#?}"
  done
  printf %x\\n $h
}

verbose() { :; }
[ "${MVNW_VERBOSE-}" != true ] || verbose() { printf %s\\n "${1-}"; }

die() {
  printf %s\\n "$1" >&2
  exit 1
}

trim() {
  # MWRAPPER-139:
  #   , entity, entity reference: &#13;
  printf '%s' "${1}" | tr -d '[:space:]'
}

# parse distributionUrl and optional distributionSha256Sum, wrapperSha256Sum
while IFS="=" read -r key value; do
  case "${key-}" in
  distributionUrl) distributionUrl=$(trim "${value-}") ;;
  distributionSha256Sum) distributionSha256Sum=$(trim "${value-}") ;;
  wrapperSha256Sum) wrapperSha256Sum=$(trim "${value-}") ;;
  wrapperVersion) wrapperVersion=$(trim "${value-}") ;;
  esac
done <"${0%/*}/.mvn/wrapper/maven-wrapper.properties"

# apply MVNW_REPOURL and calculate MAVEN_HOME
distributionUrlNameMain=${distributionUrl##*/}
distributionUrlName="${distributionUrlNameMain%%\?*}"
distributionUrlNameMain="${distributionUrlName%-bin.*}"
distributionUrlNameMain="${distributionUrlNameMain%-src.*}"
MAVEN_USER_HOME="${MAVEN_USER_HOME:-${HOME}/.m2}"
MAVEN_HOME="${MAVEN_USER_HOME}/wrapper/dists/${distributionUrlNameMain}-$(hash_string "$distributionUrl")"

exec_maven() {
  unset MVNW_VERBOSE MVNW_USERNAME MVNW_PASSWORD MVNW_REPOURL || :
  exec "$MAVEN_HOME/bin/mvn" "$@" || die "cannot exec maven"
}

if [ -d "$MAVEN_HOME" ]; then
  verbose "found existing MAVEN_HOME at $MAVEN_HOME"
  exec_maven "$@"
fi

case "${distributionUrl-}" in
*?-bin.zip | *?-bin.tar.gz | *?-src.zip | *?-src.tar.gz) ;;
*) die "distributionUrl is not valid, must match *-bin.zip or *-src.zip, but found '${distributionUrl-}'" ;;
esac

# prepare tmp dir
if TMP_DOWNLOAD_DIR="$(mktemp -d)" && [ -d "$TMP_DOWNLOAD_DIR" ]; then
  clean() { rm -rf -- "$TMP_DOWNLOAD_DIR"; }
  trap clean HUP INT TERM EXIT
else
  die "cannot create temp dir"
fi

mkdir -p -- "${MAVEN_HOME%/*}"

# Download and Install Apache Maven
verbose "Couldn't find MAVEN_HOME, downloading and installing it ..."
verbose "Downloading from: $distributionUrl"
verbose "Downloading to: $TMP_DOWNLOAD_DIR/$distributionUrlName"

# Use wget/curl to download
if command -v wget >/dev/null; then
  verbose "Found wget ... using wget"
  QUIET="--quiet"
  [ "${MVNW_VERBOSE-}" != true ] || QUIET=""
  if [ -z "${MVNW_USERNAME-}" ] || [ -z "${MVNW_PASSWORD-}" ]; then
    wget $QUIET "$distributionUrl" -O "$TMP_DOWNLOAD_DIR/$distributionUrlName" || die "wget: Failed to fetch $distributionUrl"
  else
    wget $QUIET --http-user="$MVNW_USERNAME" --http-password="$MVNW_PASSWORD" "$distributionUrl" -O "$TMP_DOWNLOAD_DIR/$distributionUrlName" || die "wget: Failed to fetch $distributionUrl"
  fi
elif command -v curl >/dev/null; then
  verbose "Found curl ... using curl"
  QUIET="--silent"
  [ "${MVNW_VERBOSE-}" != true ] || QUIET=""
  if [ -z "${MVNW_USERNAME-}" ] || [ -z "${MVNW_PASSWORD-}" ]; then
    curl $QUIET -o "$TMP_DOWNLOAD_DIR/$distributionUrlName" -L "${MVNW_REPOURL-$distributionUrl}" || die "curl: Failed to fetch $distributionUrl"
  else
    curl $QUIET --user "$MVNW_USERNAME:$MVNW_PASSWORD" -o "$TMP_DOWNLOAD_DIR/$distributionUrlName" -L "${MVNW_REPOURL-$distributionUrl}" || die "curl: Failed to fetch $distributionUrl"
  fi
else
  die "Cannot find wget or curl to download Maven distribution"
fi

# If specified, validate the SHA-256 sum of the Maven distribution zip file
if [ -n "${distributionSha256Sum-}" ]; then
  distributionSha256Result=false
  if [ "$distributionSha256Sum" = "$(sha256sum "$TMP_DOWNLOAD_DIR/$distributionUrlName" | cut -d ' ' -f 1)" ]; then
    distributionSha256Result=true
  elif [ "$distributionSha256Sum" = "$(shasum -a 256 "$TMP_DOWNLOAD_DIR/$distributionUrlName" | cut -d ' ' -f 1)" ]; then
    distributionSha256Result=true
  fi
  if [ $distributionSha256Result = false ]; then
    die "SHA-256 sum verification failed for $TMP_DOWNLOAD_DIR/$distributionUrlName"
  fi
fi

# unzip and move
if command -v unzip >/dev/null; then
  unzip ${MVNW_VERBOSE:+-q} "$TMP_DOWNLOAD_DIR/$distributionUrlName" -d "$TMP_DOWNLOAD_DIR" || die "failed to unzip"
else
  tar xzf${MVNW_VERBOSE:+v} "$TMP_DOWNLOAD_DIR/$distributionUrlName" -C "$TMP_DOWNLOAD_DIR" || die "failed to untar"
fi
printf %s\\n "$TMP_DOWNLOAD_DIR"/*
mv "$TMP_DOWNLOAD_DIR"/"$distributionUrlNameMain" "${MAVEN_HOME}" || die "fail to move MAVEN_HOME"

clean
exec_maven "$@"
