<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="IMS Gen2 - Regression Suite" verbose="1">
    <parameter name="report-name" value="IMS-Regression-Report"/>
    <listeners>
        <listener class-name="com.ims.automation.listeners.ImsTestListener"/>
    </listeners>
    <test name="Dashboard Tests">
        <classes>
            <class name="com.ims.automation.dashboard.DashboardTests"/>
        </classes>
    </test>
    <test name="Inventory Tests">
        <classes>
            <class name="com.ims.automation.inventory.InventoryTests"/>
        </classes>
    </test>
    <test name="Deployment Tests">
        <classes>
            <class name="com.ims.automation.deployment.DeploymentTests"/>
        </classes>
    </test>
    <test name="Compliance Tests">
        <classes>
            <class name="com.ims.automation.compliance.ComplianceTests"/>
        </classes>
    </test>
    <test name="Account Service Tests">
        <classes>
            <class name="com.ims.automation.accountservice.AccountServiceTests"/>
        </classes>
    </test>
    <test name="Analytics Tests">
        <classes>
            <class name="com.ims.automation.analytics.AnalyticsTests"/>
        </classes>
    </test>
</suite>
