# =============================================================================
# IMS Gen 2 — Environment Configuration
# See Docs/integration-contract.md for full contract specification.
# =============================================================================

# --- Platform Selection (required) ---
# Which adapter to load: "mock" | "aws-amplify" | "aws-cdk" | "aws-terraform" | "azure"
VITE_PLATFORM=mock

# --- Authentication (required for non-mock platforms) ---
# Auth issuer URL (Cognito User Pool URL, Entra ID authority, Auth0 domain)
VITE_AUTH_PROVIDER_URL=
# OAuth 2.0 SPA client ID from your identity provider
VITE_AUTH_CLIENT_ID=
# AWS region for Cognito (AWS platforms only)
VITE_AUTH_REGION=ap-southeast-2
# Azure AD tenant ID (Azure platform only)
# VITE_AUTH_TENANT_ID=

# --- API (required for non-mock platforms) ---
# Backend API base URL (AppSync, API Gateway, Azure Functions)
VITE_API_ENDPOINT=
# API protocol: "graphql" | "rest"
VITE_API_TYPE=graphql

# --- Optional Services ---
# Presigned URL endpoint for file uploads (firmware packages, compliance docs)
# VITE_STORAGE_ENDPOINT=
# OpenSearch / Azure AI Search endpoint for full-text and geo search
# VITE_SEARCH_ENDPOINT=
# WebSocket / SignalR endpoint for real-time device status updates
# VITE_REALTIME_ENDPOINT=
