{
  "name": "ims-gen2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/regression-suite.xml",
    "test:e2e:smoke": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/smoke-suite.xml",
    "test:e2e:module": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/module-suite.xml -Dmodule=",
    "test:e2e:headed": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/smoke-suite.xml -Dspring.profiles.active=web,test,local",
    "compliance:validate": "echo 'TODO: compliance validators'",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-query-devtools": "^5.96.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "embla-carousel-react": "8.6.0",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-router": "7.13.0",
    "react-simple-maps": "3.0.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "4.1.12",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.26.0",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
