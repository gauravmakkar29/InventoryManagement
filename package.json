{
  "name": "ims-gen2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/regression-suite.xml",
    "test:e2e:smoke": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/smoke-suite.xml",
    "test:e2e:module": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/module-suite.xml -Dmodule=",
    "test:e2e:headed": "cd e2e/ims-e2e && mvn clean test -DsuiteXmlFile=src/test/resources/suites/smoke-suite.xml -Dspring.profiles.active=web,test,local",
    "codegen": "graphql-codegen",
    "codegen:openapi": "openapi-typescript src/lib/schema/openapi.yaml -o src/lib/schema/generated/openapi.ts",
    "compliance:validate": "echo 'TODO: compliance validators'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-query-devtools": "^5.96.0",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "embla-carousel-react": "8.6.0",
    "focus-trap-react": "^12.0.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-i18next": "^17.0.2",
    "react-router": "7.13.0",
    "react-simple-maps": "3.0.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.22.0",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@playwright/test": "^1.52.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/theming": "^8.6.18",
    "@storybook/types": "^8.6.14",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^8.6.18",
    "tailwindcss": "4.1.12",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.26.0",
    "vite": "6.3.5",
    "vitest": "3.2.4",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "node scripts/check-file-length.js"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
